{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PJ Yuji Statistics",
  "version": "0.1.0",
  "identifier": "com.internal.pjjyuji.statistics",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PJ Yuji Statistics",
        "width": 1200,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
