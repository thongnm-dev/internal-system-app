{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Management Systems",
  "version": "1.0.3",
  "identifier": "com.internal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Management Systems",
        "width": 1200,
        "height": 760,
        "minWidth": 980,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico"],
    "resources": []
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/thongnm-dev/internal-system-app/releases/latest/download/latest.json"
      ],
